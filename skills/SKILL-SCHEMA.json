{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JARVIS Skill Metadata Schema",
  "description": "Schema for JARVIS skill metadata embedded in SKILL.md frontmatter",
  "type": "object",
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique skill identifier (kebab-case)",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "description": "Brief description of skill purpose (1-2 sentences)"
    },
    "metadata": {
      "type": "object",
      "description": "JARVIS-specific metadata",
      "properties": {
        "jarvis": {
          "type": "object",
          "properties": {
            "requires": {
              "type": "object",
              "description": "Required dependencies for skill execution",
              "properties": {
                "bins": {
                  "type": "array",
                  "description": "Required binary executables (CLI tools)",
                  "items": {
                    "type": "string"
                  }
                },
                "env": {
                  "type": "array",
                  "description": "Required environment variables",
                  "items": {
                    "type": "string"
                  }
                },
                "config": {
                  "type": "array",
                  "description": "Required config paths that must be truthy",
                  "items": {
                    "type": "string"
                  }
                },
                "mcp_servers": {
                  "type": "array",
                  "description": "Required MCP server names",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "primaryEnv": {
              "type": "string",
              "description": "Primary environment variable for this skill"
            },
            "domain": {
              "type": "string",
              "description": "Domain this skill belongs to",
              "enum": [
                "investment",
                "content-creation",
                "research",
                "productivity",
                "general",
                "security"
              ]
            },
            "security_level": {
              "type": "string",
              "description": "Security level for human-in-the-loop approval",
              "enum": ["low", "medium", "high"],
              "default": "medium"
            },
            "requires_approval": {
              "type": "boolean",
              "description": "Whether skill requires explicit user approval before execution",
              "default": false
            },
            "allowed_operations": {
              "type": "array",
              "description": "Allowed operations (read, write, delete, execute, network)",
              "items": {
                "type": "string",
                "enum": ["read", "write", "delete", "execute", "network"]
              },
              "default": ["read"]
            },
            "version": {
              "type": "string",
              "description": "Skill version (semantic versioning)",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "author": {
              "type": "string",
              "description": "Skill author"
            },
            "tags": {
              "type": "array",
              "description": "Tags for skill discovery and categorization",
              "items": {
                "type": "string"
              }
            },
            "integrates_with": {
              "type": "array",
              "description": "Other skills this skill integrates with",
              "items": {
                "type": "string"
              }
            },
            "feeds_into": {
              "type": "array",
              "description": "Skills that consume output from this skill",
              "items": {
                "type": "string"
              }
            },
            "consumes_from": {
              "type": "array",
              "description": "Skills that provide input to this skill",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["domain"]
        }
      }
    }
  }
}
