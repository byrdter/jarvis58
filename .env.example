# JARVIS Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# MARKET DATA API
# ============================================================================
# Yahoo Finance (via jarvis-price CLI tool)
# No API key needed - uses yfinance library

# Alpaca API (for advanced market data with 200 SMA support)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # or https://api.alpaca.markets for live

# ============================================================================
# MEMORY SYSTEM
# ============================================================================
# Memory backend (chroma, supabase, or neo4j)
MEMORY_BACKEND=chroma

# Chroma (local vector database - default, no setup needed)
# Automatically uses .chroma/ directory

# Supabase (cloud vector database)
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Neo4j (knowledge graph - future)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ============================================================================
# MCP SERVERS (Multi-Platform Integration)
# ============================================================================
# Gmail
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Google Calendar
CALENDAR_API_KEY=your_calendar_api_key

# Slack
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key

# ============================================================================
# CONTENT CREATION (Optional - for content-creation skills)
# ============================================================================
# OpenAI (for content generation)
OPENAI_API_KEY=your_openai_api_key

# Google Gemini (for image generation)
GEMINI_API_KEY=your_gemini_api_key

# ElevenLabs (for text-to-speech - Phase 2)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ============================================================================
# PATHS (Customize if needed)
# ============================================================================
# Default paths (relative to project root)
JARVIS_SKILLS_DIR=./skills
JARVIS_CLI_TOOLS_DIR=./cli-tools
JARVIS_ECOSYSTEM_DIR=./ecosystem

# If using jarvis-private (recommended for personal data)
# JARVIS_CONTEXT_DIR=../jarvis-private/context
# JARVIS_MEMORY_DIR=../jarvis-private/context/memory
# JARVIS_REPORTS_DIR=../jarvis-private/reports
# JARVIS_LOGS_DIR=../jarvis-private/logs

# ============================================================================
# CLAUDE CODE
# ============================================================================
# Claude Code settings (usually in .claude/settings.json)
# These are examples - adjust as needed

# Enable tool search (lazy loading for MCP servers)
# ENABLE_TOOL_SEARCH=true

# ============================================================================
# SECURITY
# ============================================================================
# Security level for skill execution
JARVIS_DEFAULT_SECURITY_LEVEL=medium

# Require approval for high-security operations
JARVIS_REQUIRE_APPROVAL_HIGH=true

# Audit trail location
JARVIS_AUDIT_LOG=./audit.log

# ============================================================================
# HEARTBEAT SYSTEM (Autonomous Execution)
# ============================================================================
# Enable heartbeat (24/7 proactive execution)
HEARTBEAT_ENABLED=false

# Heartbeat interval (minutes)
HEARTBEAT_INTERVAL=60

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Debug mode
DEBUG=false

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Test mode (use mock data instead of real APIs)
TEST_MODE=false

# ============================================================================
# NOTES
# ============================================================================
# - Never commit the .env file to git
# - Store API keys securely
# - Use environment-specific files (.env.development, .env.production)
# - Rotate keys regularly
# - Use least-privilege access for API keys
