{
  "name": "jarvis-video-12",
  "version": "0.1.0",
  "description": "JARVIS Video 12 — MCP Token Stack production.",
  "scripts": {
    "start": "remotion preview src/index.ts",
    "render": "remotion render src/index.ts Main ../10-videos/video-12.mp4 --codec=h264 --concurrency=4",
    "check": "tsc --noEmit --pretty false",
    "align": "python3 transcribe_and_align.py",
    "still": "remotion still src/index.ts Main out/check-frame.png --frame=250 --scale=0.25"
  },
  "dependencies": {
    "@remotion/cli": "4.0.242",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.242"
  },
  "devDependencies": {
    "@remotion/bundler": "4.0.242",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
